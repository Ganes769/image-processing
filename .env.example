# Database (used by drizzle-kit migrate/generate and by app)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://myuser:your_password_here@localhost:5432/your_database

# Optional: separate PG vars (used by src/db/connection.ts if DATABASE_URL not used)
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=your_database
# PGUSER=myuser
# PGPASSWORD=your_password_here
